{
  "name": "orion",
  "version": "1.0.5",
  "private": true,
  "scripts": {
    "build": "npx tsx build.ts",
    "watch": "npx tsx build.ts --watch",
    "typecheck": "tsc --noEmit",
    "test": "npx playwright test",
    "test:unit": "vitest run",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "scheduler:init": "npx tsx scripts/agent-scheduler.ts init",
    "scheduler:run": "npx tsx scripts/agent-scheduler.ts run",
    "scheduler:start": "npx tsx scripts/agent-scheduler.ts start",
    "scheduler:once": "npx tsx scripts/agent-scheduler.ts once"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/chrome": "^0.0.268",
    "esbuild": "^0.21.0",
    "sharp": "^0.34.5",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
