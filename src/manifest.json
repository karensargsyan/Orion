{
  "manifest_version": 3,
  "name": "Orion",
  "version": "0.7.3",
  "description": "AI browser assistant. Reads pages, fills forms, researches the web. Runs locally or via cloud APIs. Private and fast.",

  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs",
    "tabGroups",
    "activeTab",
    "sidePanel",
    "scripting",
    "webNavigation",
    "alarms",
    "offscreen",
    "debugger",
    "contextMenus",
    "notifications"
  ],

  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+O", "mac": "Alt+O" },
      "description": "Toggle Orion panel"
    },
    "quick-chat": {
      "suggested_key": { "default": "Alt+Shift+A", "mac": "Alt+Shift+A" },
      "description": "Focus Orion chat input"
    },
    "memory-search": {
      "suggested_key": { "default": "Alt+Shift+M", "mac": "Alt+Shift+M" },
      "description": "Search Orion memory"
    }
  },

  "omnibox": { "keyword": "ai" },

  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-main.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },

  "action": {
    "default_title": "Open Orion",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["privacy-policy.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
